<div class="container mt-4">
  <h1>HealthEntries</h1>
  <p class="lead">🔥 Current streak: <%= @streak %> day<%= @streak == 1 ? "" : "s" %></p>

  <div class="row mb-4">
    <div class="col-md-4">
      <div class="card text-center">
        <div class="card-body">
          <h5 class="card-title">Avg Mood</h5>
          <p class="card-text fs-3"><%= @avg_mood || "N/A" %>/5</p>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card text-center">
        <div class="card-body">
          <h5 class="card-title">Avg Energy</h5>
          <p class="card-text fs-3"><%= @avg_energy || "N/A" %>/5</p>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card text-center">
        <div class="card-body">
          <h5 class="card-title">Avg Sleep</h5>
          <p class="card-text fs-3"><%= @avg_sleep || "N/A" %> hrs</p>
        </div>
      </div>
    </div>
  </div>

  <div class="card mb-4 p-3" >
  <h5>Mood & Energy</h5>
    <%= line_chart [
          { name: "Mood", data: @chart_data_mood },
          { name: "Energy", data: @chart_data_energy },
        ], colors: ["#4CAF50", "#FF9800"] %>
  </div>

  <% @health_entries.each do |entry| %>
    <div class="card mb-2 border-<%= mood_colour(entry.mood) %>">
      <div class="card-body">
        <h5><%= link_to entry.date, entry %></h5>
        <p class="mb-1">Mood: <%= entry.mood %>/5</p>
        <p class="mb-1">Energy: <%= entry.energy %>/5</p>
        <p class="mb-0">Sleep: <%= entry.sleep_hours %> hr</p>
      </div>
    </div>
  <% end %>
    <div>
      <%= paginate @health_entries %>
    </div>
      <%= link_to "Add new entry", new_health_entry_path, class: "btn btn-primary mt-3" %>
      <%= link_to "Export CSV", export_health_entries_path(format: :csv), class: "btn btn-success mt-3" %>
  </div>
