<div class="container mt-4">
  <h1>HealthEntries</h1>

  <div class="row mb-4">
    <div class="col-md-4">
      <div class="card text-center">
        <div class="card-body">
          <h5 class="card-title">Avg Mood</h5>
          <p class="card-text fs-3"><%= @avg_mood || "N/A" %>/5</p>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card text-center">
        <div class="card-body">
          <h5 class="card-title">Avg Energy</h5>
          <p class="card-text fs-3"><%= @avg_energy || "N/A" %>/5</p>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card text-center">
        <div class="card-body">
          <h5 class="card-title">Avg Sleep</h5>
          <p class="card-text fs-3"><%= @avg_sleep || "N/A" %> hrs</p>
        </div>
      </div>
    </div>
  </div>

  <% @health_entries.each do |entry|  %>
    <div class="card mb-2 border-<%= mood_colour(entry.mood) %>">
      <div class="card-body">
        <h5><%= link_to entry.date, entry %></h5>
        <p class="mb-1">Mood: <%= entry.mood %>/5</p>
        <p class="mb-1">Energy: <%= entry.energy %>/5</p>
        <p class="mb-0">Sleep: <%= entry.sleep_hours %> hr</p>
      </div>
    </div>
  <% end %>
  <%= link_to "Add new entry", new_health_entry_path, class: "btn btn-primary mt-3" %>
</div>
